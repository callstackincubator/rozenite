{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"]
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck", "build"],
      "outputs": []
    },
    "@rozenite/agent-sdk#typecheck": {
      "dependsOn": [
        "^build",
        "^typecheck",
        "build",
        "@rozenite/controls-plugin#build",
        "@rozenite/file-system-plugin#build",
        "@rozenite/mmkv-plugin#build",
        "@rozenite/network-activity-plugin#build",
        "@rozenite/react-navigation-plugin#build",
        "@rozenite/redux-devtools-plugin#build",
        "@rozenite/storage-plugin#build",
        "@rozenite/tanstack-query-plugin#build"
      ],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^build", "build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build", "build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  }
}
