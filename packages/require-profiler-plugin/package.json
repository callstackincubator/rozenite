{
  "name": "@rozenite/require-profiler-plugin",
  "version": "1.7.0-rc.0",
  "description": "Metro require profiler for Rozenite.",
  "type": "module",
  "main": "./dist/react-native/index.cjs",
  "module": "./dist/react-native/index.js",
  "types": "./dist/react-native/index.d.ts",
  "homepage": "https://github.com/callstackincubator/rozenite#readme",
  "bugs": {
    "url": "https://github.com/callstackincubator/rozenite/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/callstackincubator/rozenite.git"
  },
  "exports": {
    ".": {
      "types": "./dist/react-native/index.d.ts",
      "import": "./dist/react-native/index.js",
      "require": "./dist/react-native/index.cjs"
    },
    "./package.json": "./package.json",
    "./metro": {
      "types": "./dist/metro/index.d.ts",
      "import": "./dist/metro/index.js",
      "require": "./dist/metro/index.cjs"
    }
  },
  "scripts": {
    "build": "rozenite build",
    "dev": "rozenite dev",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@rozenite/plugin-bridge": "workspace:*",
    "@rozenite/tools": "workspace:*",
    "nanoevents": "^9.1.0"
  },
  "devDependencies": {
    "@rozenite/vite-plugin": "workspace:*",
    "@types/react": "catalog:",
    "autoprefixer": "^10.4.21",
    "lucide-react": "^0.263.1",
    "metro-config": "*",
    "postcss": "^8.5.6",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-flame-graph": "^1.4.0",
    "react-json-tree": "^0.20.0",
    "react-native": "catalog:",
    "react-native-web": "^0.21.2",
    "rozenite": "workspace:*",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.3",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
